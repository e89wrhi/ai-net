{
  "AppOptions": {
    "Name": "AI-Modular-Monolith"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "PostgresOptions": {
    "ConnectionString": {
      "Chat": "Server=localhost;Port=5432;Database=chat_modular_monolith;User Id=postgres;Password=postgres;Include Error Detail=true",
      "Identity": "Server=localhost;Port=5432;Database=identity_modular_monolith;User Id=postgres;Password=postgres;Include Error Detail=true",
      "Image": "Server=localhost;Port=5432;Database=image_modular_monolith;User Id=postgres;Password=postgres;Include Error Detail=true",
      "Assistant": "Server=localhost;Port=5432;Database=assisitant_modular_monolith;User Id=postgres;Password=postgres;Include Error Detail=true",
      "Meeting": "Server=localhost;Port=5432;Database=meeting_modular_monolith;User Id=postgres;Password=postgres;Include Error Detail=true",
      "Payment": "Server=localhost;Port=5432;Database=payment_modular_monolith;User Id=postgres;Password=postgres;Include Error Detail=true",
      "Resume": "Server=localhost;Port=5432;Database=resume_modular_monolith;User Id=postgres;Password=postgres;Include Error Detail=true",
      "User": "Server=localhost;Port=5432;Database=user_modular_monolith;User Id=postgres;Password=postgres;Include Error Detail=true"
    }
  },
  "MongoOptions": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "ai_modular_monolith_read"
  },
  "EventStoreOptions": {
    "ConnectionString": "esdb://localhost:2113?tls=false"
  },
  "Jwt": {
    "Authority": "https://localhost:3000",
    "Audience": "ai-modular-monolith"
  },
  "PersistMessageOptions": {
    "Interval": 30,
    "Enabled": true,
    "ConnectionString": "Server=localhost;Port=5432;Database=persist_message;User Id=postgres;Password=postgres;Include Error Detail=true"
  },
  "HealthOptions": {
    "Enabled": false
  }, 
  "ObservabilityOptions": {
    "InstrumentationName": "ai_modular_monolith_service",
    "OTLPOptions": {
      "OTLPGrpExporterEndpoint": "http://localhost:4317"
    },
    "AspireDashboardOTLPOptions": {
      "OTLPGrpExporterEndpoint": "http://localhost:4319"
    },
    "ZipkinOptions": {
      "HttpExporterEndpoint": "http://localhost:9411/api/v2/spans"
    },
    "JaegerOptions": {
      "OTLPGrpcExporterEndpoint": "http://localhost:14317",
      "HttpExporterEndpoint": "http://localhost:14268/api/traces"
    },
    "UsePrometheusExporter": true,
    "UseOTLPExporter": true,
    "UseAspireOTLPExporter": true,
    "UseGrafanaExporter": false,
    "ServiceName": "AI Modular Monolith Service"
  },
  "AllowedHosts": "*"
}
